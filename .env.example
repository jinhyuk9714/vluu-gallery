# Copy this file to `.env.local` for local development.
# In Vercel, configure the same values separately for Preview and Production.

NEXT_PUBLIC_SANITY_PROJECT_ID=ppsg7ml5
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_STUDIO_URL=https://personal-gallery.sanity.studio

# Local default. For Vercel Preview, set this to the preview deployment URL.
# For Vercel Production, use the default `https://<project>.vercel.app` domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared webhook secret used by Sanity when calling `/api/revalidate`.
SANITY_REVALIDATE_SECRET=replace-me
